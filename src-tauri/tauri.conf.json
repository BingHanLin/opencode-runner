{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "opencode runner",
  "version": "0.8.0",
  "identifier": "dev.opencode.runner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "opencode runner",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BingHanLin/opencode-runner/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBNkEyQkZBREMyOTgyQTEKUldTaGdpbmMraXRxeWpPc2VWelZjQjQxUnMxNE83ZGw0S250Sm1ac215NUMxYlRsWDNMM25SUm8K"
    }
  }
}
